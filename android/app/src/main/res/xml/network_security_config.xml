<?xml version="1.0" encoding="utf-8"?>
<!-- Atrio Network Security Configuration -->
<!-- Enforces HTTPS-only and restricts trusted domains -->
<network-security-config>
    <!-- Block cleartext (HTTP) traffic globally -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Localhost: cleartext allowed for debug only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- Supabase backend: HTTPS enforced, system CAs only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">easypanel.host</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Google Maps APIs: HTTPS enforced -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">maps.google.com</domain>
        <domain includeSubdomains="true">maps.gstatic.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Google Fonts CDN -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">fonts.googleapis.com</domain>
        <domain includeSubdomains="true">fonts.gstatic.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
